# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local agent docs
/AGENTS.md
/CLAUDE.md

# private content skeletons
/data/blogs/*
!/data/blogs/README.md
/data/projects/*
!/data/projects/README.md
/data/friends/*
!/data/friends/README.md
/data/about_photos/*
!/data/about_photos/README.md
/data/life_photos/*
!/data/life_photos/README.md
!/data/life_photos/footprint.json
/data/life_photos/progress_bar/*
